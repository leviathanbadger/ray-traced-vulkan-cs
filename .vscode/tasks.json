{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build RayTutorial.App",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/RayTutorial.App/RayTutorial.App.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "build RayTutorial.App (Windows native)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "WIN_REPO=$(wslpath -w \"$PWD\"); powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"Set-Location \\\"$WIN_REPO\\\"; & \\\"$env:ProgramFiles\\\\dotnet\\\\dotnet.exe\\\" build \\\".\\\\src\\\\RayTutorial.App\\\\RayTutorial.App.csproj\\\" -p:BaseIntermediateOutputPath=obj-win\\\\ -p:BaseOutputPath=bin-win\\\\ /property:GenerateFullPaths=true /consoleloggerparameters:NoSummary\""
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
