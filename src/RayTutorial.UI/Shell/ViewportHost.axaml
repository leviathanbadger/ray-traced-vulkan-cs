<UserControl
    x:Class="RayTutorial.UI.Shell.ViewportHost"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root">
  <Grid>
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
      <TextBlock
          Text="{Binding StatusTitle, ElementName=Root}"
          HorizontalAlignment="Center"
          FontSize="18"
          FontWeight="SemiBold" />
      <TextBlock
          Width="280"
          Text="{Binding StatusDetail, ElementName=Root}"
          TextAlignment="Center"
          TextWrapping="Wrap" />
    </StackPanel>
  </Grid>
</UserControl>
