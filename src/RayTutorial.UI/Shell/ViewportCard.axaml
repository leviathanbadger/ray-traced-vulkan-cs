<UserControl
    x:Class="RayTutorial.UI.Shell.ViewportCard"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:RayTutorial.UI.Shell"
    x:Name="Root">
  <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="8">
    <TextBlock Classes="viewportTitle" Text="{Binding Title, ElementName=Root}" />
    <TextBlock Grid.Row="1" Classes="viewportSubtitle" Text="{Binding Subtitle, ElementName=Root}" />
    <Border Grid.Row="2" Classes="viewportSurface">
      <shell:ViewportHost
          ViewportId="{Binding ViewId, ElementName=Root}"
          HostService="{Binding HostService, ElementName=Root}" />
    </Border>
    <Grid Grid.Row="3" ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
      <Border Classes="miniChip">
        <TextBlock Text="Camera Linked" />
      </Border>
      <Border Grid.Column="1" Classes="miniChip">
        <TextBlock Text="AOV Ready" />
      </Border>
      <TextBlock Grid.Column="2" HorizontalAlignment="Right" Classes="eyebrow" Text="{Binding Body, ElementName=Root}" />
    </Grid>
  </Grid>
</UserControl>
