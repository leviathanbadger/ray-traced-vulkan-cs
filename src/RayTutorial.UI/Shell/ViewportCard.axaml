<UserControl
    x:Class="RayTutorial.UI.Shell.ViewportCard"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:RayTutorial.UI.Shell"
    x:Name="Root">
  <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
      <StackPanel Spacing="2">
        <TextBlock Classes="viewportTitle" Text="{Binding Title, ElementName=Root}" />
        <TextBlock Classes="viewportSubtitle" Text="{Binding Subtitle, ElementName=Root}" />
      </StackPanel>

      <ComboBox
          x:Name="AovSelector"
          Grid.Column="1"
          Width="130"
          ItemsSource="{Binding AovOptions, ElementName=Root}"
          SelectedItem="{Binding SelectedAov, ElementName=Root}" />

      <ComboBox
          x:Name="PresentationSelector"
          Grid.Column="2"
          Width="110"
          ItemsSource="{Binding PresentationOptions, ElementName=Root}"
          SelectedItem="{Binding SelectedPresentation, ElementName=Root}" />

      <Button Grid.Column="3" Classes="toolbarButton" Content="Surface">
        <Button.Flyout>
          <Flyout Placement="BottomEdgeAlignedRight">
            <StackPanel MinWidth="240" Spacing="8">
              <TextBlock Classes="eyebrow" Text="{Binding SurfaceStatus, ElementName=Root}" />
              <TextBlock Text="{Binding EnabledOutputsSummary, ElementName=Root}" TextWrapping="Wrap" />
              <ComboBox
                  x:Name="RenderModeSelector"
                  ItemsSource="{Binding RenderModeOptions, ElementName=Root}"
                  SelectedItem="{Binding SelectedRenderMode, ElementName=Root}" />
              <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <ComboBox
                    x:Name="SamplesPerPixelSelector"
                    ItemsSource="{Binding SamplesPerPixelOptions, ElementName=Root}"
                    SelectedItem="{Binding SelectedSamplesPerPixel, ElementName=Root}" />
                <ComboBox
                    x:Name="MaxBounceSelector"
                    Grid.Column="1"
                    ItemsSource="{Binding MaxBounceOptions, ElementName=Root}"
                    SelectedItem="{Binding SelectedMaxBounces, ElementName=Root}" />
              </Grid>
              <Button
                  x:Name="ApplySurfaceSettingsButton"
                  Classes="toolbarButton"
                  Content="Apply Surface Settings" />
              <ComboBox
                  x:Name="EnableOutputSelector"
                  ItemsSource="{Binding AvailableOutputOptions, ElementName=Root}"
                  SelectedItem="{Binding SelectedOutputToEnable, ElementName=Root}" />
              <Button
                  x:Name="EnableOutputButton"
                  Classes="toolbarButton"
                  Content="Enable Output for This Pane" />
            </StackPanel>
          </Flyout>
        </Button.Flyout>
      </Button>

      <Button Grid.Column="4" Classes="toolbarButton" Content="Actions">
        <Button.Flyout>
          <Flyout Placement="BottomEdgeAlignedRight">
            <StackPanel MinWidth="220" Spacing="8">
              <TextBlock Classes="eyebrow" Text="Viewport Actions" />
              <Button x:Name="CompareActionButton" Classes="toolbarButton" Content="Compare Raw vs Denoised" />
              <Button x:Name="InspectTlasActionButton" Classes="toolbarButton" Content="Inspect TLAS" />
              <Button x:Name="CloneSurfaceActionButton" Classes="toolbarButton" Content="Clone to New Surface" />
            </StackPanel>
          </Flyout>
        </Button.Flyout>
      </Button>
    </Grid>

    <Border Grid.Row="1" Classes="viewportSurface">
      <shell:ViewportHost
          ViewportId="{Binding ViewId, ElementName=Root}"
          RenderSurfaceId="{Binding RenderSurfaceId, ElementName=Root}"
          HostService="{Binding HostService, ElementName=Root}" />
    </Border>
    <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="8">
      <Border Classes="miniChip">
        <TextBlock Text="{Binding SelectedRenderMode, ElementName=Root}" />
      </Border>
      <Border Grid.Column="1" Classes="miniChip">
        <TextBlock Text="{Binding SelectedAov, ElementName=Root}" />
      </Border>
      <Border Grid.Column="2" Classes="miniChip">
        <TextBlock Text="{Binding SurfaceStatus, ElementName=Root}" />
      </Border>
      <TextBlock Grid.Column="3" HorizontalAlignment="Right" Classes="eyebrow" Text="{Binding EnabledOutputsSummary, ElementName=Root}" />
    </Grid>
  </Grid>
</UserControl>
