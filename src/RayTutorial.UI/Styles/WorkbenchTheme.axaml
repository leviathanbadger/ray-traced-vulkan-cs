<Styles xmlns="https://github.com/avaloniaui">
  <Style Selector="Window">
    <Setter Property="Background" Value="#0F1115" />
    <Setter Property="Foreground" Value="#F3F4F7" />
    <Setter Property="FontFamily" Value="Segoe UI, DejaVu Sans, Sans-Serif" />
  </Style>

  <Style Selector="Border.panel">
    <Setter Property="Background" Value="#161A20" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="Padding" Value="18" />
    <Setter Property="BorderBrush" Value="#253042" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BoxShadow" Value="0 12 30 0 #55000000" />
  </Style>

  <Style Selector="Border.topBar">
    <Setter Property="Background" Value="#11161D" />
    <Setter Property="Padding" Value="18,14" />
    <Setter Property="BorderBrush" Value="#202B3A" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
  </Style>

  <Style Selector="Border.statusBar">
    <Setter Property="Background" Value="#11161D" />
    <Setter Property="Padding" Value="16,12" />
    <Setter Property="BorderBrush" Value="#202B3A" />
    <Setter Property="BorderThickness" Value="0,1,0,0" />
  </Style>

  <Style Selector="TextBlock.panelTitle">
    <Setter Property="FontSize" Value="17" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.panelSubtitle">
    <Setter Property="Foreground" Value="#B0BAC8" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <Style Selector="TextBlock.eyebrow">
    <Setter Property="Foreground" Value="#95A3B6" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button.toolbarButton">
    <Setter Property="Background" Value="#1B2230" />
    <Setter Property="BorderBrush" Value="#2D3A52" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="12,8" />
  </Style>

  <Style Selector="Button.accentButton">
    <Setter Property="Background" Value="#C96A1C" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="14,9" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Border.modeChip">
    <Setter Property="Background" Value="#182434" />
    <Setter Property="BorderBrush" Value="#30445F" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="12,7" />
  </Style>

  <Style Selector="Border.lessonCard">
    <Setter Property="Background" Value="#10151D" />
    <Setter Property="BorderBrush" Value="#222E40" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="14" />
    <Setter Property="Margin" Value="0,0,0,10" />
  </Style>

  <Style Selector="TextBlock.lessonCardEyebrow">
    <Setter Property="Foreground" Value="#7DB5FF" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>

  <Style Selector="TextBlock.lessonCardTitle">
    <Setter Property="FontSize" Value="15" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.lessonCardSummary">
    <Setter Property="Foreground" Value="#B8C1CE" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <Style Selector="Border.viewportPane">
    <Setter Property="Background" Value="#141820" />
    <Setter Property="CornerRadius" Value="18" />
    <Setter Property="Padding" Value="16" />
    <Setter Property="BorderBrush" Value="#273244" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="TextBlock.viewportTitle">
    <Setter Property="FontSize" Value="17" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.viewportSubtitle">
    <Setter Property="Foreground" Value="#90A1B5" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <Style Selector="Border.viewportSurface">
    <Setter Property="Background" Value="#0B0F14" />
    <Setter Property="BorderBrush" Value="#1C2430" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="16" />
  </Style>

  <Style Selector="Border.inspectorCard">
    <Setter Property="Background" Value="#11161D" />
    <Setter Property="BorderBrush" Value="#212C3A" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="14" />
  </Style>

  <Style Selector="Border.miniChip">
    <Setter Property="Background" Value="#1C2431" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="8,4" />
  </Style>
</Styles>
